<Window x:Class="MorphosPowerPointAddIn.Dialogs.ReplaceColorsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replace Color"
        WindowStartupLocation="CenterOwner"
        Width="600"
        Height="470"
        MinWidth="380"
        MinHeight="390"
        ResizeMode="CanResize"
        Background="#F4F0E7"
        SizeChanged="Window_SizeChanged"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFDF8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F7F2E8" />
        <SolidColorBrush x:Key="LineBrush" Color="#D8CFBF" />
        <SolidColorBrush x:Key="HoverBrush" Color="#F1EADF" />
        <SolidColorBrush x:Key="TextBrush" Color="#171513" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6A6359" />
        <SolidColorBrush x:Key="AccentBrush" Color="#5F88AD" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E7F0F9" />
        <SolidColorBrush x:Key="WarningBrush" Color="#C88E13" />
        <SolidColorBrush x:Key="WarningSoftBrush" Color="#FFF3CF" />

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HoverBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#C5BBA9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#E9E2D5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#51799B" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#51799B" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#466887" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#466887" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
    </Window.Resources>

    <Border Margin="14"
            Padding="16"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Replace color"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           Text="Replace the selected direct RGB color with one theme color or one custom color."
                           TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,16,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="14"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="44"
                                Height="44"
                                Margin="0,0,12,0"
                                Background="{Binding SourceBrush, Mode=OneWay}"
                                BorderBrush="#AFA391"
                                BorderThickness="1"
                                CornerRadius="10" />

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Selected color"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="12.5"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold">
                                <Run Text="{Binding SourceHexText, Mode=OneWay}" />
                                <Run Text="   " />
                                <Run Text="{Binding SourceRgbText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource MutedBrush}"
                                       Text="{Binding SourceUsageSummary, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                            <Border Margin="0,8,0,0"
                                    Padding="8,4"
                                    Background="{StaticResource WarningSoftBrush}"
                                    BorderBrush="#E6C66F"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Visibility="{Binding ThemeMatchVisibility, Mode=OneWay}">
                                <TextBlock Text="{Binding ThemeMatchText, Mode=OneWay}"
                                           Foreground="#8C6410"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,12,0,0"
                        Padding="14"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Replace with"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="12.5"
                                   FontWeight="SemiBold" />
                        <ComboBox Margin="0,12,0,0"
                                  ItemsSource="{Binding ThemeChoices, Mode=OneWay}"
                                  SelectedItem="{Binding SelectedThemeChoice, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="DisplayName" />
                        <WrapPanel Margin="0,12,0,0">
                            <Button Content="Pick custom color"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="PickColor_Click" />
                            <Button Margin="8,0,0,0"
                                    Content="Clear"
                                    Style="{StaticResource ActionButtonStyle}"
                                    IsEnabled="{Binding HasInstructions, Mode=OneWay}"
                                    Click="ResetRow_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,12,0,0"
                        Padding="14"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="#CBDAEA"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid x:Name="PreviewGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="PreviewSourceSwatch"
                                Width="32"
                                Height="32"
                                Background="{Binding SourceBrush, Mode=OneWay}"
                                BorderBrush="#AFA391"
                                BorderThickness="1"
                                CornerRadius="8"
                                VerticalAlignment="Center" />
                        <TextBlock x:Name="PreviewArrowText"
                                   Grid.Column="1"
                                   Margin="12,0"
                                   Text="->"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Border x:Name="PreviewReplacementSwatch"
                                Grid.Column="2"
                                Width="32"
                                Height="32"
                                Background="{Binding ReplacementBrush, Mode=OneWay}"
                                BorderBrush="#AFA391"
                                BorderThickness="1"
                                CornerRadius="8"
                                VerticalAlignment="Center" />
                        <StackPanel x:Name="PreviewSummaryPanel"
                                    Grid.Column="3"
                                    Margin="12,0,0,0">
                            <TextBlock Text="Queued replacement"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding PreviewText, Mode=OneWay}"
                                       Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <WrapPanel Grid.Row="2"
                       HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Margin="0,0,8,8"
                        MinWidth="96"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="Cancel_Click" />
                <Button Content="Replace"
                        Margin="0,0,0,8"
                        MinWidth="96"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsEnabled="{Binding HasInstructions, Mode=OneWay}"
                        Click="Replace_Click" />
            </WrapPanel>
        </Grid>
    </Border>
</Window>
